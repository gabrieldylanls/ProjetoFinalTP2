# Doxygen configuration for ProjetoFinalTP2.

PROJECT_NAME           = "Sistema de Gerência de Compras e Compartilhamento de Preços"
PROJECT_BRIEF          = "Aplicação Flask/SQLite para compras, listas, preços compartilhados e administração de catálogo"
PROJECT_NUMBER         = "1.0"
OUTPUT_DIRECTORY       = docs_doxygen
CREATE_SUBDIRS         = NO

INPUT                  = app \
                         docs/doxygen \
                         README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.py \
                         *.md
EXCLUDE_PATTERNS       = */__pycache__/* \
                         *.pyc
USE_MDFILE_AS_MAINPAGE = docs/doxygen/mainpage.md

EXTENSION_MAPPING      = py=Python
OPTIMIZE_OUTPUT_JAVA   = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
SEARCHENGINE           = YES

QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
HAVE_DOT               = NO
